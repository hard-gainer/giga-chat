# Base64(client_id:client_secret)
VITE_GIGACHAT_CREDENTIALS=

# One of: GIGACHAT_API_PERS | GIGACHAT_API_B2B | GIGACHAT_API_CORP
VITE_GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Proxy endpoints used by the frontend
VITE_GIGACHAT_AUTH_URL=/proxy/gigachat/oauth
VITE_GIGACHAT_API_URL=/proxy/gigachat/chat/completions
